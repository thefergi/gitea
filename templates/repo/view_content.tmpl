{{$isTreePathRoot := not .TreeNames}}

<div class="repo-view-content-data tw-hidden" data-document-title="{{ctx.RootData.Title}}" data-document-title-common="{{ctx.RootData.PageTitleCommon}}"></div>
<div id="tia-config" class="tw-hidden" data-repo-link="{{.RepoLink}}" data-ref="{{.RefTypeNameSubURL}}"></div>
{{template "repo/sub_menu" .}}
<div class="repo-button-row">
	<div class="repo-button-row-left">
	{{if not $isTreePathRoot}}
		{{template "repo/view_file_tree_toggle_button" .}}
	{{end}}

	{{template "repo/branch_dropdown" dict
		"Repository" .Repository
		"ShowTabBranches" true
		"ShowTabTags" true
		"CurrentRefType" .RefFullName.RefType
		"CurrentRefShortName" .RefFullName.ShortName
		"CurrentTreePath" .TreePath
		"RefLinkTemplate" "{RepoLink}/src/{RefType}/{RefShortName}/{TreePath}"
		"AllowCreateNewRef" .CanCreateBranch
		"ShowViewAllRefsEntry" true
	}}

	{{if and .PullRequestCtx.CanCreateNewPull .RefFullName.IsBranch}}
		{{$compareLink := .PullRequestCtx.MakeDefaultCompareLink .BranchName}}
		<a id="new-pull-request" role="button" class="ui compact basic button" href="{{QueryBuild $compareLink "expand" 1}}"
			data-tooltip-content="{{ctx.Locale.Tr "repo.pulls.compare_changes"}}">
			{{svg "octicon-git-pull-request"}}
		</a>
	{{end}}

	{{if and $isTreePathRoot .Repository.IsTemplate}}
		<a role="button" class="ui primary compact button" href="{{AppSubUrl}}/repo/create?template_id={{.Repository.ID}}">
			{{ctx.Locale.Tr "repo.use_template"}}
		</a>
	{{end}}

	{{if not $isTreePathRoot}}
		{{$treeNameIdxLast := Eval (len .TreeNames) "-" 1}}
		<span class="breadcrumb">
			<a class="section" href="{{.RepoLink}}/src/{{.RefTypeNameSubURL}}" title="{{.Repository.Name}}">{{StringUtils.EllipsisString .Repository.Name 30}}</a>
			{{- range $i, $v := .TreeNames -}}
				<span class="breadcrumb-divider">/</span>
				{{- if eq $i $treeNameIdxLast -}}
					<span class="active section" title="{{$v}}">{{$v}}</span>
					<button class="btn interact-fg tw-mx-1" data-clipboard-text="{{$.TreePath}}" data-tooltip-content="{{ctx.Locale.Tr "copy_path"}}">{{svg "octicon-copy" 14}}</button>
				{{- else -}}
					{{$p := index $.Paths $i}}<span class="section"><a href="{{$.BranchLink}}/{{PathEscapeSegments $p}}" title="{{$v}}">{{$v}}</a></span>
				{{- end -}}
			{{- end -}}
		</span>
	{{end}}
	</div>

	<div class="repo-button-row-right">
		<div class="repo-file-search-container"
				data-global-init="initRepoFileSearch"
				data-repo-link="{{.RepoLink}}"
				data-current-ref-name-sub-url="{{.RefTypeNameSubURL}}"
				data-tree-list-url="{{.RepoLink}}/tree-list/{{.RefTypeNameSubURL}}"
				data-no-results-text="{{ctx.Locale.Tr "repo.find_file.no_matching"}}"
				data-placeholder="{{ctx.Locale.Tr "repo.find_file.go_to_file"}}"
		><div class="ui small input global-shortcut-wrapper"><input placeholder="{{ctx.Locale.Tr "repo.find_file.go_to_file"}}"><kbd>T</kbd></div></div>

		{{if .RefFullName.IsBranch}}
			{{$addFilePath := .TreePath}}
			{{if .IsViewFile}}
				{{if gt (len .TreeNames) 1}}
					{{$addFilePath = StringUtils.Join (slice .TreeNames 0 (Eval (len .TreeNames) "-" 1)) "/"}}
				{{else}}
					{{$addFilePath = ""}}
				{{end}}
			{{end}}
			<button class="ui dropdown basic compact jump button repo-add-file" {{if not .Repository.CanEnableEditor}}disabled{{end}}>
				{{ctx.Locale.Tr "repo.editor.add_file"}}
				{{svg "octicon-triangle-down" 14 "dropdown icon"}}
				<div class="menu">
					<a class="item" href="{{.RepoLink}}/_new/{{.BranchName | PathEscapeSegments}}/{{$addFilePath | PathEscapeSegments}}">
						{{svg "octicon-file-added" 16 "tw-mr-2"}}{{ctx.Locale.Tr "repo.editor.new_file"}}
					</a>
					{{if .RepositoryUploadEnabled}}
					<a class="item" href="{{.RepoLink}}/_upload/{{.BranchName | PathEscapeSegments}}/{{$addFilePath | PathEscapeSegments}}">
						{{svg "octicon-upload" 16 "tw-mr-2"}}{{ctx.Locale.Tr "repo.editor.upload_file"}}
					</a>
					{{end}}
					<a class="item" href="{{.RepoLink}}/_diffpatch/{{.BranchName | PathEscapeSegments}}/{{$addFilePath | PathEscapeSegments}}">
						{{svg "octicon-diff" 16 "tw-mr-2"}}{{ctx.Locale.Tr "repo.editor.patch"}}
					</a>
				</div>
			</button>

			{{if and (not .IsViewFile) (not $isTreePathRoot)}}
			<button class="ui dropdown basic compact jump button tw-px-3" data-tooltip-content="{{ctx.Locale.Tr "repo.more_operations"}}">
				{{svg "octicon-kebab-horizontal"}}
				<div class="menu">
					<a class="item" data-clipboard-text="{{ctx.AppFullLink}}{{.Repository.Link}}/src/commit/{{.CommitID}}/{{PathEscapeSegments .TreePath}}">
						{{svg "octicon-link" 16}}{{ctx.Locale.Tr "repo.file_copy_permalink"}}
					</a>
					{{if and (not $.DisableDownloadSourceArchives) $.RefFullName}}
						<div class="divider"></div>
						<a class="item muted archive-link" href="{{$.RepoLink}}/archive/{{PathEscapeSegments $.RefFullName.ShortName}}.zip?path={{PathEscapeSegments .TreePath}}" rel="nofollow">{{svg "octicon-file-zip"}}{{ctx.Locale.Tr "repo.download_directory_as" "ZIP"}}</a>
						<a class="item muted archive-link" href="{{$.RepoLink}}/archive/{{PathEscapeSegments $.RefFullName.ShortName}}.tar.gz?path={{PathEscapeSegments .TreePath}}" rel="nofollow">{{svg "octicon-file-zip"}}{{ctx.Locale.Tr "repo.download_directory_as" "TAR.GZ"}}</a>
					{{end}}
					{{if and .Repository.CanContentChange (not $isTreePathRoot)}}
						<div class="divider"></div>
						<a class="item tw-text-danger" href="{{.RepoLink}}/_delete/{{.BranchName | PathEscapeSegments}}/{{.TreePath | PathEscapeSegments}}">
							{{svg "octicon-trash" 16}}{{ctx.Locale.Tr "repo.editor.delete_this_directory"}}
						</a>
					{{end}}
				</div>
			</button>
			{{end}}
		{{end}}
		<!-- Only show clone panel in repository home page -->
		{{if $isTreePathRoot}}
			{{template "repo/clone_panel" .}}
		{{end}}
		{{if and (not $isTreePathRoot) (not .IsViewFile) (not .IsBlame)}}{{/* IsViewDirectory (not home), TODO: split the templates, avoid using "if" tricks */}}
			<a class="ui compact button" href="{{.RepoLink}}/commits/{{.RefTypeNameSubURL}}/{{.TreePath | PathEscapeSegments}}">
				{{svg "octicon-history"}}{{ctx.Locale.Tr "repo.file_history"}}
			</a>
		{{end}}
	</div>
</div>
{{if .IsViewFile}}
	{{template "repo/view_file" .}}
{{else if .IsBlame}}
	{{template "repo/blame" .}}
{{else}}{{/* IsViewDirectory */}}
	{{if $isTreePathRoot}}
		{{template "repo/code/upstream_diverging_info" .}}
		{{/* TIA Spike 2 / Stage A: if project.json is at the repo root, the navigator
		below replaces the plain file list. The project-tree sidebar (replacing Gitea's
		raw-file tree) is wired by the always-present script further below. */}}
		<div id="tia-project-view" class="tw-hidden"></div>
	{{end}}
	{{template "repo/view_list" .}}
	{{if and .ReadmeExist (or .RenderAsMarkup .IsPlainText)}}
		{{template "repo/view_file" .}}
	{{end}}
{{end}}
{{/* TIA: always-present style + script. Navigator renders on root (into
#tia-project-view); sidebar replaces #view-file-tree on file/dir views. */}}
<style id="tia-style">
#tia-project-view{margin:12px 0;font-family:var(--fonts-regular,Segoe UI,Roboto,sans-serif);color:var(--color-text)}
.tia-proj-head{display:flex;align-items:baseline;gap:14px;padding:10px 14px;margin-bottom:14px;background:var(--color-box-body);border:1px solid var(--color-secondary);border-radius:8px}
.tia-proj-title{font-size:20px;font-weight:700}
.tia-proj-gen{font-size:12px;color:var(--color-text-light-2)}
.tia-plc{margin-bottom:18px;background:var(--color-box-body);border:1px solid var(--color-secondary);border-radius:8px;overflow:hidden}
.tia-plc>h3{margin:0;padding:8px 14px;font-size:15px;background:var(--color-secondary-alpha-30);border-bottom:1px solid var(--color-secondary);display:flex;align-items:center;gap:8px}
.tia-plc>h3:before{content:"";display:inline-block;width:10px;height:10px;background:#5b8;clip-path:polygon(0 0,55% 0,100% 50%,55% 100%,0 100%,45% 50%)}
.tia-grp{padding:6px 14px 10px}
.tia-grp:not(:last-child){border-bottom:1px solid var(--color-secondary-alpha-40)}
.tia-grp-h{font-size:12px;text-transform:uppercase;letter-spacing:.04em;color:var(--color-text-light-2);margin:6px 0}
.tia-cnt{background:var(--color-secondary-alpha-50);border-radius:10px;padding:0 8px;font-size:11px}
.tia-list{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:4px}
.tia-list li{margin:0}
.tia-list a{display:flex;align-items:center;gap:8px;padding:5px 8px;border-radius:6px;text-decoration:none;color:var(--color-text)}
.tia-list a:hover{background:var(--color-secondary-alpha-40)}
.tia-badge{display:inline-block;min-width:34px;text-align:center;font-size:10px;font-weight:700;padding:2px 5px;border-radius:4px;color:#fff;background:#888;letter-spacing:.03em}
.tia-b-fc{background:#1f6feb}.tia-b-fb{background:#8957e5}.tia-b-db{background:#db6d28}.tia-b-ob{background:#238636}.tia-b-udt{background:#6e7681}.tia-b-scr{background:#d6399b}
.tia-nm{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tia-num{font-size:11px;color:var(--color-text-light-2);font-variant-numeric:tabular-nums}
.tia-tagtable{display:inline-block;padding:4px 10px;border-radius:6px;background:var(--color-secondary-alpha-30);text-decoration:none;color:var(--color-text);font-size:13px}
.tia-tagtable:hover{background:var(--color-secondary-alpha-50)}
#tia-sidebar{font-family:var(--fonts-regular,Segoe UI,Roboto,sans-serif);font-size:13px;color:var(--color-text);padding:4px 0 12px}
#tia-sidebar .tia-sb-proj{font-weight:700;padding:4px 10px 8px;border-bottom:1px solid var(--color-secondary-alpha-40);margin-bottom:4px}
#tia-sidebar .tia-sb-node{padding:3px 10px 3px 6px;border-radius:5px;cursor:pointer;display:flex;align-items:center;gap:5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--color-text);text-decoration:none}
#tia-sidebar .tia-sb-node:hover{background:var(--color-secondary-alpha-40)}
#tia-sidebar .tia-sb-node.tia-active{background:var(--color-primary-alpha-30);font-weight:600;box-shadow:inset 2px 0 0 var(--color-primary)}
#tia-sidebar .tia-sb-leaf{padding-left:24px}
#tia-sidebar .tia-sb-group{padding-left:16px;font-size:11px;text-transform:uppercase;letter-spacing:.03em;color:var(--color-text-light-2);margin-top:6px}
#tia-sidebar .tia-sb-badge{font-size:9px;font-weight:700;padding:1px 4px;border-radius:3px;color:#fff;background:#888}
#tia-sidebar details>summary{list-style:none;cursor:pointer;padding:5px 10px;display:flex;align-items:center;gap:5px;font-weight:600}
#tia-sidebar details>summary::-webkit-details-marker{display:none}
#tia-sidebar details>summary:before{content:"▸";color:var(--color-text-light-2);font-size:10px;display:inline-block;transition:transform .1s}
#tia-sidebar details[open]>summary:before{transform:rotate(90deg)}
#tia-sidebar .tia-sb-num{font-size:10px;color:var(--color-text-light-2);margin-left:auto;padding-left:6px}
#tia-sidebar .tia-sb-nm{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
/* TIA-style SVG icons (replace emoji/clunky badges) */
.tia-ic{display:inline-flex;width:16px;height:16px;flex:0 0 auto;align-self:center;color:var(--color-text-light-2);vertical-align:middle}
.tia-ic .tia-svg{width:100%;height:100%;display:block}
.tia-ic-fc{color:#1f6feb}.tia-ic-fb{color:#8957e5}.tia-ic-ob{color:#238636}.tia-ic-db{color:#db6d28}.tia-ic-udt{color:#6e7681}.tia-ic-scr{color:#d6399b}
.tia-proj-head .tia-ic{width:24px;height:24px;color:var(--color-primary)}
.tia-plc>h3 .tia-ic{color:#2da44e}
.tia-plc>h3:before,#tia-sidebar .tia-sb-proj:before{content:none!important}
.tia-grp-h{display:flex;align-items:center;gap:6px}
.tia-tagtable{display:inline-flex!important;align-items:center;gap:6px}
.tia-list a .tia-ic{margin-right:2px}
/* Stage B: ladder diff panel + in-page ladder pieces (renderer CSS lives in its iframe) */
#tia-diff-panel{font-family:var(--fonts-regular,Segoe UI,Roboto,sans-serif);font-size:13px;color:var(--color-text);margin:8px 0 14px;border:1px solid var(--color-secondary);border-radius:8px;background:var(--color-box-body);padding:10px 12px}
.tia-diff-head{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:4px}
.tia-diff-path{font-family:ui-monospace,Consolas,monospace;color:var(--color-text-light-2);font-size:12px}
.tia-diff-flt{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:400;padding:2px 8px;border:1px solid var(--color-secondary);border-radius:6px;cursor:pointer}
.tia-diff-sum{margin-left:auto;font-size:12px;color:var(--color-text-light-2)}
.tia-diff-oldsha{font-size:11px;color:var(--color-text-light-2);font-family:ui-monospace,Consolas,monospace;margin-bottom:8px}
.tia-diff-row{border:1px solid var(--color-secondary);border-radius:6px;margin:6px 0;overflow:hidden}
.tia-diff-n{padding:5px 10px;font-weight:600;background:var(--color-secondary-alpha-30);display:flex;align-items:center;gap:8px}
.tia-diff-tag{font-size:11px;font-weight:700;padding:1px 7px;border-radius:4px;color:#fff}
.tia-diff-grid{display:grid;grid-template-columns:1fr 1fr}
.tia-diff-cell{padding:8px 10px;border-left:1px solid var(--color-secondary-alpha-40);min-height:34px}
.tia-diff-cell:first-child{border-left:none}
.tia-diff-side{font-size:10px;text-transform:uppercase;color:var(--color-text-light-2);margin-bottom:4px}
.tia-diff-empty{padding:14px;color:var(--color-text-light-2);text-align:center}
.tia-d-added{border-color:#3fb950}.tia-d-added .tia-diff-n{background:#1f6feb0d}.tia-d-added .tia-diff-tag{background:#238636}
.tia-d-removed .tia-diff-n{background:#f8514910}.tia-d-removed .tia-diff-tag{background:#d73a49}
.tia-d-modified .tia-diff-n{background:#d299221a}.tia-d-modified .tia-diff-tag{background:#dbab09}
.tia-d-value .tia-diff-n{background:#a371f714}.tia-d-value .tia-diff-tag{background:#8957e5}
.tia-d-unchanged .tia-diff-tag{background:#6e7681}
.tia-d-added .tia-diff-cell:nth-child(2){background:#1f6feb0a}.tia-d-removed .tia-diff-cell:nth-child(1){background:#f851490a}
.tia-diff-seg{display:inline-flex;border:1px solid var(--color-secondary);border-radius:6px;overflow:hidden}
.tia-vm{border:none;background:transparent;padding:4px 12px;font-size:12px;cursor:pointer;color:var(--color-text)}
.tia-vm.tia-vm-on{background:var(--color-primary);color:#fff}
.tia-diff-uni{padding:6px 12px;margin:0;border-radius:0;border-left:4px solid transparent}
.tia-diff-uni.tia-dim{opacity:.5}.tia-diff-uni.tia-strike{text-decoration:line-through;opacity:.65}
.tia-d-added .tia-diff-uni{background:#e6ffed;border-left-color:#238636}
.tia-d-removed .tia-diff-uni{background:#ffeef0;border-left-color:#d73a49}
.tia-d-modified .tia-diff-uni{background:#fff4e0;border-left-color:#dbab09}
.tia-d-value .tia-diff-uni{background:#f6f0ff;border-left-color:#8957e5}
#tia-compare-btn{font-size:12px}
/* in-page ladder pieces (diff), same look as the iframe renderer */
#tia-diff-panel .tia-ladder,#tia-diff-panel .tia-rung{font-family:ui-monospace,Consolas,monospace;font-size:13px;line-height:1.6}
#tia-diff-panel .tia-rail{color:#888;padding:0 3px}#tia-diff-panel .tia-wire{color:#888}
#tia-diff-panel .tia-series{display:inline-flex;align-items:center}
#tia-diff-panel .tia-parallel{display:inline-flex;flex-direction:column;border-left:2px solid #888;border-right:2px solid #888;margin:0 4px}
#tia-diff-panel .tia-parallel .tia-series{padding:2px 6px}
#tia-diff-panel .tia-ct{display:inline-flex;align-items:center;border:1px solid #666;border-radius:4px;background:#fff;padding:2px 8px;margin:0 3px}
#tia-diff-panel .tia-bar{color:#999;margin:0 2px}
#tia-diff-panel .tia-coil{border:1px solid #070;color:#050;background:#efe;border-radius:10px;padding:2px 10px;margin-left:8px;font-weight:bold}
#tia-diff-panel .tia-empty{color:var(--color-text-light-2);font-style:italic}
/* Stage C: tag table / data type content */
.tia-content{font-family:var(--fonts-regular,Segoe UI,Roboto,sans-serif);font-size:13px;color:var(--color-text);margin:8px 0 14px;border:1px solid var(--color-secondary);border-radius:8px;background:var(--color-box-body);padding:10px 12px}
.tia-cp-head{font-size:14px;margin-bottom:8px;color:var(--color-text-light-2)}
.tia-cp-head b{color:var(--color-text)}
.tia-table{width:100%;border-collapse:collapse}
.tia-table th{text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.03em;color:var(--color-text-light-2);padding:5px 10px;border-bottom:1px solid var(--color-secondary);background:var(--color-secondary-alpha-20)}
.tia-table td{padding:4px 10px;border-bottom:1px solid var(--color-secondary-alpha-40);vertical-align:top}
.tia-table tr:hover td{background:var(--color-secondary-alpha-20)}
.tia-table .tia-nm{font-family:ui-monospace,Consolas,monospace;font-weight:600;white-space:nowrap}
.tia-table .tia-addr{font-family:ui-monospace,Consolas,monospace;color:var(--color-text-light-2);white-space:nowrap}
.tia-table .tia-dtype{display:inline-block;font-size:11px;font-weight:700;padding:1px 6px;border-radius:4px;background:#1f6feb22;color:#1f6feb}
.tia-table .tia-cmt{color:var(--color-text-light-2)}
</style>
<script nonce="{{ctx.CspScriptNonce}}">
(function(){
	var cfg = document.getElementById('tia-config');
	if (!cfg || !window.fetch) return;
	var repoLink = cfg.getAttribute('data-repo-link');
	var ref = cfg.getAttribute('data-ref');
	var esc = function(s){ return String(s).replace(/[&<>"']/g, function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];}); };
	var seg = function(s){ return encodeURIComponent(String(s)); };
	var fileUrl = function(){ var p = Array.prototype.slice.call(arguments); return repoLink + '/src/' + ref + '/' + p.map(seg).join('/'); };
	var bc = function(ty){ ty=String(ty||'').toUpperCase(); if(ty.indexOf('FB')>=0)return'fb'; if(ty.indexOf('FC')>=0)return'fc'; if(ty.indexOf('DB')>=0)return'db'; if(ty.indexOf('OB')>=0)return'ob'; return ''; };
	var shortType = function(ty){ ty=String(ty||'').toUpperCase(); if(ty.indexOf('INSTANCE')>=0)return'IDB'; if(ty.indexOf('GLOBAL')>=0)return'DB'; if(ty.indexOf('FB')>=0)return'FB'; if(ty.indexOf('FC')>=0)return'FC'; if(ty.indexOf('OB')>=0)return'OB'; return ty.slice(0,3)||'?'; };
	var SVG = {
		project: '<svg class="tia-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M2 14V7l3 2V7l3 2V7l3 2V7l3 2v5z"/><path d="M2 14h12"/></svg>',
		plc: '<svg class="tia-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3.5" y="4.5" width="9" height="7" rx="1"/><path d="M6 4.5V3M10 4.5V3M6 13v-1.5M10 13v-1.5M3.5 7H2M3.5 9H2M12.5 7H14M12.5 9H14"/><rect x="6.5" y="7" width="3" height="2" rx=".4" fill="currentColor" stroke="none"/></svg>',
		hmi: '<svg class="tia-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><rect x="2" y="3" width="12" height="8" rx="1"/><path d="M6 13.5h4M8 11v2.5"/></svg>',
		folder: '<svg class="tia-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M2 5a1 1 0 0 1 1-1h2.6l1.4 1.4H13a1 1 0 0 1 1 1V12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1z"/></svg>',
		block: '<svg class="tia-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><rect x="3" y="4" width="10" height="8" rx="1"/><path d="M3 7.5h10M6 4V2.6M10 4V2.6"/></svg>',
		db: '<svg class="tia-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><ellipse cx="8" cy="4" rx="4.2" ry="1.6"/><path d="M3.8 4v8c0 .9 1.9 1.6 4.2 1.6s4.2-.7 4.2-1.6V4"/></svg>',
		tag: '<svg class="tia-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M2.5 8.5l5-5H12v4.5l-5 5z"/><circle cx="9.5" cy="6.5" r="1"/></svg>',
		udt: '<svg class="tia-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M5.5 3c-2.5 0-2.5 10 0 10M10.5 3c2.5 0 2.5 10 0 10"/><rect x="6" y="6" width="4" height="4" rx=".5"/></svg>',
